function f_serviceconf {
  if [[ $LXC == "1" ]]; then
    return
  fi

  echo "[$SCRIPT_COUNT] Harden systemd service configurations"

  local SSH_SVC="ssh.service"
  if [[ "$DISTRO" == "debian" ]]; then
    SSH_SVC="sshd.service"
  fi

  local -A SERVICE_OVERRIDES
  SERVICE_OVERRIDES=(
    ["$SSH_SVC"]="hardening-sshd.conf"
    ["postfix@-.service"]="hardening-postfix.conf"
    ["psad.service"]="hardening-psad.conf"
    ["rsyslog.service"]="hardening-rsyslog.conf"
    ["auditd.service"]="hardening-auditd.conf"
    ["unattended-upgrades.service"]="hardening-unattended-upgrades.conf"
  )

  for svc in "${!SERVICE_OVERRIDES[@]}"; do
    local conf="${SERVICE_OVERRIDES[$svc]}"

    if ! systemctl list-unit-files "$svc" --no-pager 2>/dev/null | grep -q "$svc"; then
      continue
    fi

    local drop_in_dir="/etc/systemd/system/${svc}.d"
    mkdir -p "$drop_in_dir"
    cp "./config/${conf}" "${drop_in_dir}/hardening.conf"
    chmod 0644 "${drop_in_dir}/hardening.conf"
  done

  systemctl daemon-reload

  if [[ $VERBOSE == "Y" ]]; then
    echo "Service hardening overrides installed:"
    find /etc/systemd/system -name "hardening.conf" -path "*.d/*" 2>/dev/null
    echo
  fi

  ((SCRIPT_COUNT++))
}
