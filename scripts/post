function f_post {
  if [[ $LXC == "1" ]]; then
    return
  fi

  echo "[$SCRIPT_COUNT] Post processing"

  $APT install --no-install-recommends fwupd

  if [[ "$DISTRO" == "ubuntu" ]]; then
    $APT install --no-install-recommends secureboot-db
  fi

  if [[ $VERBOSE == "Y" ]]; then
    update-grub
  else
    update-grub 2>/dev/null
  fi

  find /boot/ -type f -name '*.cfg' -exec chmod 0400 {} \;

  ((SCRIPT_COUNT++))
}
