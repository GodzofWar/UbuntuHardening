function f_usbguard {
  echo "[$SCRIPT_COUNT] Enable usbguard"

  $APT install --no-install-recommends usbguard

  local USBGUARD_TMP
  USBGUARD_TMP="$(mktemp)"
  usbguard generate-policy > "$USBGUARD_TMP"
  install -m 0600 -o root -g root "$USBGUARD_TMP" /etc/usbguard/rules.conf
  rm -f "$USBGUARD_TMP"

  systemctl enable usbguard.service
  systemctl start usbguard.service

  if [[ $VERBOSE == "Y" ]]; then
    systemctl status usbguard.service --no-pager
    echo
  fi

  ((SCRIPT_COUNT++))
}
